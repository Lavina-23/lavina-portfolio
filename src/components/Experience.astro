  <!-- Projects -->
  <div class="border-3 border-main-red mt-10">
    <div class="bg-main-red text-main-white p-2">
      <h1 class="text-xl font-semibold text-main-white font-serif">Projects</h1>
    </div>
    <div class="p-10 grid gap-10">
      <ul class="grid gap-10">
        {
          projects.map((project) => (
            <li class="grid gap-5 w-full">
              <img
                src={project.image.src}
                alt={project.title}
                fetchpriority="high"
              />
              <div class="flex gap-5 w-full">
                <svg
                  class="w-6 h-6"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 576 512"
                >
                  <path
                    fill="#86302b"
                    d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"
                  />
                </svg>
                <div class="text-main-red w-full">
                  <div class="flex justify-between">
                    <h1 class="text-2xl font-extrabold font-serif max-w-lg">
                      {project.title}
                    </h1>
                    <div class="border-2 border-dashed border-main-red w-fit h-fit p-1.5 font-basic font-semibold text-xs">
                      <a
                        href={project.link}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {project.projectLinkLabel}
                      </a>
                    </div>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-sm font-medium font-basic">
                      {project.role}
                    </span>
                  </div>
                  <p class="font-basic text-sm mt-3 list-none">
                    {project.description}
                  </p>
                  <div class="mt-4 gap-2 font-basic font-medium text-xs text-main-white flex">
                    {project.skills.map((skill) => (
                      <div class="bg-main-red w-fit py-1 px-3">
                        <span>{skill}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
